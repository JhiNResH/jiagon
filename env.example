NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
# Required for server-side private account state sync.
# Copy the app verification key from the Privy dashboard.
# PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BNB_TESTNET_ADMIN=0x046aB9D6aC4EA10C42501ad89D9a741115A76Fa9
BNB_RECEIPT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# BNB_MINTER_PRIVATE_KEY=never-commit-real-private-keys
# JIAGON_MINT_API_TOKEN=use-a-random-32-plus-character-server-token
# JIAGON_APP_MINT_ENABLED=true
# Solana credit MVP adapter. Leave SOLANA_CREDIT_PROGRAM_ID unset until the
# Anchor/Metaplex program is deployed; the app will still produce signed PDA
# seed payloads for demo and testing.
# SOLANA_CLUSTER=devnet
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_CREDIT_PROGRAM_ID=
# JIAGON_SOLANA_ADAPTER_SECRET=use-a-random-32-plus-character-server-token
# Purpose-bound restaurant deposit lending. The Anchor program expects a vault
# SPL token account owned by the jiagon-vault-authority PDA, plus a merchant or
# escrow token account that receives the devnet USDC deposit.
# SOLANA_CREDIT_PAYMENT_MINT=
# SOLANA_CREDIT_VAULT_TOKEN_ACCOUNT=
# SOLANA_CREDIT_MERCHANT_ESCROW_TOKEN_ACCOUNT=
# Devnet-only server demo path for restaurant deposit draw/repay. Do not use
# mainnet keys here; this route sends real devnet transactions when enabled.
# JIAGON_CREDIT_DEVNET_DEMO_ENABLED=false
# SOLANA_CREDIT_VERIFIER_SECRET_KEY=
# SOLANA_CREDIT_DEMO_OWNER_PUBLIC_KEY=
# SOLANA_CREDIT_DEMO_OWNER_SECRET_KEY=
# SOLANA_CREDIT_DEMO_BORROWER_TOKEN_ACCOUNT=
# Bubblegum V2 receipt cNFT minting. Create a Bubblegum V2 tree first, then
# configure the tree and server-side devnet minter. The minter must be the tree
# creator/delegate unless the tree is public.
# SOLANA_BUBBLEGUM_TREE=
# SOLANA_BUBBLEGUM_COLLECTION=
# SOLANA_BUBBLEGUM_MINTER_SECRET_KEY=
# SOLANA_BUBBLEGUM_DEFAULT_LEAF_OWNER=
# Merchant-issued receipt MVP. Use a trusted app origin for claim links; deployed
# environments should set an issuer key and submit it as x-jiagon-merchant-key.
# JIAGON_APP_ORIGIN=http://localhost:3000
# JIAGON_MERCHANT_ISSUER_KEY=use-a-random-32-plus-character-server-token
# JIAGON_MERCHANT_RECEIPT_SIGNING_SECRET=use-a-separate-random-32-plus-character-server-token
# JIAGON_ALLOW_DEMO_MERCHANT_ISSUE=false
# DATABASE_URL=postgres://user:password@host:5432/database
# DATABASE_SSL=true
